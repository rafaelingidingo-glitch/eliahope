generator client {
  // Prisma 7: "prisma-client" replaces "prisma-client-js" (old name deprecated)
  provider = "prisma-client"
  // Required in Prisma 7: explicit output path (no longer defaults to node_modules)
  output   = "../src/generated/prisma"
}

datasource db {
  // ─── Database-Agnostic Configuration ─────────────────────────────────
  // The `provider` must be a literal string (Prisma does NOT support env() here).
  // Change it to match your DATABASE_URL, then run:
  //   npx prisma generate && npx prisma db push
  //
  // Localhost (SQLite):     provider = "sqlite"
  // Vercel / Neon (PG):     provider = "postgresql"
  // PlanetScale / RDS:      provider = "mysql"
  //
  // NOTE: In Prisma 7, the connection URL is configured in prisma.config.ts
  // and passed at runtime via driver adapters in src/lib/db.ts.
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────
// Using Prisma enums for type-safe status fields.
// NOTE: SQLite does not support native enums — Prisma emulates them as strings.
// When switching to PostgreSQL, these become real DB enums automatically.

enum DonationStatus {
  pending
  processing
  successful
  failed
  cancelled
}

enum DonationMethod {
  mpesa
  crdb
  airtel
  tigo
  halopesa
  azampesa
  bank_transfer
}

enum DonationType {
  one_time
  monthly
}

enum VolunteerStatus {
  pending
  approved
  rejected
  inactive
}

enum ChildStatus {
  available
  sponsored
  graduated
  inactive
}

enum SponsorFrequency {
  monthly
  quarterly
  annually
  one_time
}

enum SponsorStatus {
  active
  paused
  cancelled
}

enum NewsletterStatus {
  active
  unsubscribed
}

enum EmailType {
  newsletter_welcome
  donation_confirmation
  admin_otp
  newsletter_broadcast
}

enum EmailStatus {
  sent
  failed
  resent
}

enum OtpPurpose {
  forgot_password
  donation_confirm
  newsletter_confirm
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin")
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String
  image       String?
  status      String   @default("upcoming")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([date])
}

model GalleryImage {
  id          String   @id @default(cuid())
  url         String
  title       String?
  category    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model Donation {
  id                String         @id @default(cuid())
  donorName         String
  donorEmail        String?
  donorPhone        String?
  // For PostgreSQL: add @db.Decimal(12, 2) for precise monetary values
  amount            Decimal
  currency          String         @default("TZS")
  method            DonationMethod
  type              DonationType   @default(one_time)
  campaignId        String?
  campaign          Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  status            DonationStatus @default(pending)
  transactionId     String?
  mpesaReceipt      String?
  crdbAccountHolder String?
  crdbAccountNumber String?
  crdbReference     String?
  message           String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([transactionId])
  @@index([status])
  @@index([campaignId])
  @@index([createdAt])
  @@index([method])
}

model PaymentProof {
  id         String         @id @default(cuid())
  donorName  String
  donorPhone String
  // For PostgreSQL: add @db.Decimal(12, 2)
  amount     Decimal
  receiptUrl String
  campaignId String?
  campaign   Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  status     String         @default("pending")
  adminNotes String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([status])
}

model Campaign {
  id          String    @id @default(cuid())
  title       String
  description String
  // For PostgreSQL: add @db.Decimal(12, 2) for precise monetary values
  goal        Decimal
  raised      Decimal   @default(0)
  image       String?
  status      String    @default("active")
  donations   Donation[]
  proofs      PaymentProof[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model Volunteer {
  id         String         @id @default(cuid())
  name       String
  email      String
  phone      String?
  skills     String?
  motivation String?
  status     VolunteerStatus @default(pending)
  programId  String?
  program    Program?       @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([status])
  @@index([email])
}

model Child {
  id          String         @id @default(cuid())
  name        String
  age         Int?
  gender      String?
  story       String?
  photo       String?
  status      ChildStatus    @default(available)
  program     String?
  sponsors    Sponsor[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
}

model Sponsor {
  id        String          @id @default(cuid())
  name      String
  email     String
  phone     String?
  childId   String?
  // For PostgreSQL: add @db.Decimal(12, 2)
  amount    Decimal
  frequency SponsorFrequency @default(monthly)
  status    SponsorStatus   @default(active)
  startDate DateTime        @default(now())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  child     Child?          @relation(fields: [childId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([email])
}

model Newsletter {
  id        String           @id @default(cuid())
  name      String
  email     String           @unique
  status    NewsletterStatus @default(active)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([status])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  image       String?
  author      String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  content   String
  image     String?
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([featured])
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  website   String?
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SuccessStory {
  id          String   @id @default(cuid())
  childName   String
  title       String
  beforeStory String
  afterStory  String
  beforeImage String?
  afterImage  String?
  quote       String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([read])
  @@index([createdAt])
}

model Program {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  icon        String?
  image       String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  volunteers  Volunteer[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([active])
}

model Stat {
  id    String @id @default(cuid())
  label String
  value Int
  icon  String?
  order Int    @default(0)
}

model OtpCode {
  id        String     @id @default(cuid())
  email     String
  code      String
  purpose   OtpPurpose @default(forgot_password)
  verified  Boolean    @default(false)
  expiresAt DateTime
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([email, purpose, verified])
  @@index([expiresAt])
}

model EmailLog {
  id         String      @id @default(cuid())
  to         String
  subject    String
  type       EmailType
  status     EmailStatus @default(sent)
  resentFrom String?
  createdAt  DateTime    @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
}
