DATABASE_URL=file:/home/z/my-project/db/custom.db

# ================================================================
# ADMIN AUTHENTICATION
# ================================================================
# Admin login credentials (used by /api/admin/login)
ADMIN_EMAIL=admin@eliashope.org
ADMIN_PASSWORD=EliaHope2024!
# API token for securing admin API routes (Bearer token auth)
# Generate a strong random string for production, e.g.: openssl rand -hex 32
ADMIN_API_TOKEN=eliashope_admin_dev_token_2024_change_in_production

# ================================================================
# AZAMPAY PAYMENT GATEWAY
# ================================================================
# Register at https://sandbox.azampay.co.tz for sandbox credentials
# Register at https://checkout.azampay.co.tz for production credentials
# Set AZAMPAY_ENV to 'live' when ready for production
AZAMPAY_APP_NAME=
AZAMPAY_CLIENT_ID=
AZAMPAY_CLIENT_SECRET=
AZAMPAY_API_KEY=
AZAMPAY_ENV=sandbox
# Webhook secret for verifying AzamPay callback signatures
# Obtain from AzamPay dashboard when available
AZAMPAY_WEBHOOK_SECRET=

# ================================================================
# PAYMENT LIMITS
# ================================================================
# Minimum donation amount in TZS (default: 500)
DONATION_MIN_AMOUNT=500
# Maximum donation amount in TZS (default: 10000000 = 10 million)
DONATION_MAX_AMOUNT=10000000

# ================================================================
# MERCHANT BANK DETAILS (for CRDB bank transfer display)
# ================================================================
# These are YOUR organization's bank details shown to donors
# so they know where to transfer money (for manual bank transfer)
MERCHANT_BANK_NAME=CRDB Bank
MERCHANT_BANK_ACCOUNT_NAME=Elia's Hope Community
MERCHANT_BANK_ACCOUNT_NUMBER=
MERCHANT_BANK_BRANCH=Mwanza

# ================================================================
# SITE CONFIGURATION
# ================================================================
# The base URL of your deployed site (used for AzamPay callback URL)
# AzamPay webhook will be sent to: NEXT_PUBLIC_SITE_URL/api/donate/azampay/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ================================================================
# RESEND EMAIL SERVICE
# ================================================================
# Get your API key from https://resend.com/api-keys
# Set to 'demo' to run in simulation mode (logs emails to console)
RESEND_API_KEY=demo
# The email address to send from (must be verified in Resend dashboard)
# For sandbox/testing, use onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev
